{
  "name": "medvision-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "MedVision Medical Appointment Platform - Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --runInBand",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --runInBand --coverage",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --watch",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --runInBand tests/unit/",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --runInBand tests/integration/",
    "test:security": "cross-env NODE_OPTIONS=--experimental-vm-modules dotenv -e .env.test -- jest --runInBand tests/security/",
    "db:test:push": "dotenv -e .env.test -- npx prisma db push",
    "db:test:reset": "dotenv -e .env.test -- npx prisma migrate reset --force",
    "postinstall": "prisma generate",
    "build": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pusher": "^5.3.4"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "prisma": "^5.10.2",
    "supertest": "^7.0.0"
  }
}

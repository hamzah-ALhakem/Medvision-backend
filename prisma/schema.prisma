// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Users (Doctors, Patients, Admin)
model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  role          Role     @default(PATIENT)
  
  accountStatus AccountStatus @default(ACTIVE) @map("account_status")

  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?
  gender        String?
  city          String?
  specialty     String?
  clinicAddress String?  @map("clinic_address")
  licenseNumber String?  @map("license_number")
  bio           String?
  image         String?

  isEmailVerified      Boolean   @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // SECURITY (SEC-04): Track failed login attempts for per-account lockout.
  // After 5 consecutive failures the account is locked for 15 minutes.
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  // SECURITY (SEC-05): Incremented on password change to invalidate all
  // existing sessions. Tokens carry this version; mismatch = 403.
  tokenVersion        Int       @default(0) @map("token_version")

  doctorSchedules       Schedule[]
  appointmentsAsDoctor  Appointment[] @relation("DoctorAppointments")
  appointmentsAsPatient Appointment[] @relation("PatientAppointments")
  sentMessages          Message[]     @relation("SentMessages")
  receivedMessages      Message[]     @relation("ReceivedMessages")
  notifications         Notification[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// 2. Doctor Availability Schedules
model Schedule {
  id        Int      @id @default(autoincrement())
  dayOfWeek String   @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  isActive  Boolean  @default(true) @map("is_active")
  
  doctorId  Int      @map("doctor_id")
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek], name: "unique_doctor_day")
  @@index([doctorId])
  @@map("schedules")
}

// 3. Appointments
model Appointment {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date
  time            String
  reason          String?
  status          Status   @default(PENDING)
  
  patientId       Int      @map("patient_id")
  patient         User     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  
  doctorId        Int      @map("doctor_id")
  doctor          User     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([patientId])
  @@index([doctorId])
  @@index([status, date])
  @@map("appointments")
}

// 4. Messages (Chat)
model Message {
  id         Int      @id @default(autoincrement())
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  
  senderId   Int      @map("sender_id")
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  
  receiverId Int      @map("receiver_id")
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@map("messages")
}

// 5. Notifications
model Notification {
  id        Int      @id @default(autoincrement())
  message   String
  type      String
  relatedId Int?     @map("related_id")
  isRead    Boolean  @default(false) @map("is_read")
  
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

// 6. Medical Labs
model Lab {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  phone     String?
  rating    Float    @default(0.0)
  image     String?
  
  services  LabService[]

  @@map("labs")
}

model LabService {
  id      Int    @id @default(autoincrement())
  name    String
  price   Float
  
  labId   Int    @map("lab_id")
  lab     Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  @@map("lab_services")
}

// Enums
enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Status {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AccountStatus {
  PENDING
  ACTIVE
  REJECTED
}